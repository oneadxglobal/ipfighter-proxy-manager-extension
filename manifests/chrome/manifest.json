{
  "manifest_version": 3,
  "name": "IPFighter Proxy Manager",
  "version": "1.0.0",
  "description": "Professional proxy manager with smart rules, privacy protection & multi-proxy support",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestAuthProvider",
    "alarms",
    "webNavigation",
    "privacy",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-off-16.png",
      "32": "icons/icon-off-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "IPFighter Proxy Manager"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-48.png",
    "32": "icons/icon-48.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://cdn.jsdelivr.net https://flagcdn.com; connect-src 'self' https://time.hidemyacc.com"
  }
}