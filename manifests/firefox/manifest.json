{
  "manifest_version": 2,
  "name": "IPFighter Proxy Manager",
  "version": "1.0.0",
  "description": "Professional proxy manager with smart rules, privacy protection & multi-proxy support",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "privacy",
    "alarms",
    "<all_urls>"
  ],
  "background": {
    "page": "background/background.html"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-off-16.png",
      "32": "icons/icon-off-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "IPFighter Proxy Manager"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-48.png",
    "32": "icons/icon-48.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "support@ipfighter.com",
      "strict_min_version": "91.1.0"
    }
  }
}